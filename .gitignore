# ─── Credentials & Auth (NEVER commit) ───────────────────
.credentials.json
mcp-needs-auth-cache.json
workflow/.rdchat_password
workflow/.rdchat_token.json

# ─── Runtime state (session-specific, auto-generated) ────
backups/
cache/
debug/
downloads/
file-history/
ide/
plans/
plugins/
projects/
session-env/
shell-snapshots/
statsig/
telemetry/
todos/

# ─── Runtime cache files ─────────────────────────────────
stats-cache.json

# ─── Workflow Guardian runtime state ─────────────────────
# config.json IS tracked; state files are not
workflow/state-*.json
workflow/guardian-crash.log

# ─── Memory Vector Service runtime ────────────────────────
memory/_vectordb/*.lance
memory/_vectordb/*.lance/**
memory/_vectordb/service.pid
memory/_vectordb/service.log

# ─── ACT-R access logs (runtime, auto-generated) ──────────
memory/*.access.json
**/memory/*.access.json

# ─── Staging area (temp files, session prompts) ──────────
memory/_staging/

# ─── Episodic atoms (TTL 24d, auto-generated) ─────────────
memory/episodic/

# ─── Distant memory archive (expired atoms) ───────────────
memory/_distant/

# ─── User-specific config (per-user, auto-generated) ──────
USER.md
USER-*.md

# ─── User-specific atoms (hardware, local env) ────────────
memory/hardware.md

# ─── Session transcripts (huge, not needed in repo) ───────
projects/*/*.jsonl
projects/*/*/

# ─── Nested .claude (auto-generated by Claude Code) ───────
.claude/

# ─── Node.js runtimes (portable, not tracked) ────────────
tools/node22/

# ─── Vector DB eval/audit logs (local diagnostics) ──────
memory/_vectordb/audit.log
memory/_vectordb/eval-results-*.json

# ─── Playwright MCP (browser automation cache) ──────────
.playwright-mcp/

# ─── Dashboard screenshots (local artifacts) ────────────
dashboard-*.png

# ─── Python cache ────────────────────────────────────────
__pycache__/
*.pyc

# ─── OS / Editor ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
