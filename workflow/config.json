{
  "atom_debug": false,
  "enabled": true,
  "stop_gate_max_blocks": 2,
  "min_files_to_block": 2,
  "remind_after_turns": 3,
  "max_reminders": 3,
  "stale_threshold_hours": 24,
  "dashboard_port": 3848,
  "sync_keywords": [
    "同步",
    "sync",
    "commit",
    "提交",
    "結束",
    "收工"
  ],
  "completion_indicators": [
    "已同步",
    "同步完成",
    "已更新",
    "已提交",
    "committed"
  ],
  "vector_search": {
    "enabled": true,
    "service_port": 3849,
    "embedding_backend": "ollama",
    "embedding_model": "qwen3-embedding",
    "fallback_backend": "sentence-transformers",
    "fallback_model": "BAAI/bge-m3",
    "ollama_base_url": "http://127.0.0.1:11434",
    "ollama_llm_model": "qwen3:1.7b",
    "ollama_backends": {
      "rdchat-direct": {
        "base_url": "http://192.168.199.130:11434",
        "llm_model": "qwen3.5:latest",
        "embedding_model": "qwen3-embedding:latest",
        "priority": 1,
        "enabled": true,
        "think": true,
        "llm_num_predict": 8192
      },
      "rdchat": {
        "base_url": "https://rdchat.uj.com.tw/ollama",
        "auth": {
          "type": "bearer_ldap",
          "login_url": "https://rdchat.uj.com.tw/api/v1/auths/ldap",
          "password_file": "~/.claude/workflow/.rdchat_password"
        },
        "llm_model": "qwen3.5:latest",
        "embedding_model": "qwen3-embedding:latest",
        "priority": 2,
        "enabled": true,
        "think": true,
        "llm_num_predict": 8192
      },
      "local": {
        "base_url": "http://127.0.0.1:11434",
        "llm_model": "qwen3:1.7b",
        "embedding_model": "qwen3-embedding",
        "priority": 3,
        "think": false,
        "llm_num_predict": 2048
      }
    },
    "search_top_k": 5,
    "search_min_score": 0.65,
    "search_timeout_ms": 3500,
    "auto_start_service": true,
    "auto_index_on_change": true
  },
  "write_gate": {
    "enabled": true,
    "auto_threshold": 0.5,
    "ask_threshold": 0.3,
    "dedup_score": 0.8,
    "skip_on_explicit_user": true
  },
  "episodic": {
    "auto_generate": true,
    "min_files": 1,
    "min_duration_seconds": 120
  },
  "_unused_cleanup": "cleanup/session_awareness/decay 設定僅供 memory-audit.py --enforce 使用，guardian 不讀取",
  "cross_session": {
    "enabled": true,
    "min_score": 0.75,
    "promote_threshold": 2,
    "suggest_threshold": 4,
    "timeout_seconds": 5
  },
  "self_iteration": {
    "decay_half_life_days": 30,
    "promote_min_confirmations": 20,
    "archive_score_threshold": 0.3,
    "oscillation_window": 3,
    "oscillation_threshold": 2,
    "review_interval": 6
  },
  "hot_cache": {
    "enabled": true,
    "quick_extract_timeout": 15,
    "quick_extract_num_predict": 512,
    "quick_extract_min_chars": 100,
    "max_summary_tokens": 100,
    "deep_overwrite": true
  },
  "response_capture": {
    "enabled": true,
    "session_end_max_chars": 20000,
    "session_end_max_items": 5,
    "session_end_timeout_seconds": 10,
    "classification_default": "[臨]",
    "per_turn": {
      "enabled": true,
      "min_new_chars": 500,
      "max_items": 3,
      "skip_cross_session": true,
      "cooldown_seconds": 120
    },
    "failure_extraction": {
      "enabled": true,
      "cooldown_seconds": 180,
      "max_items": 2,
      "strong_keywords": ["又錯了", "沒修好", "還是壞", "修復失敗", "一樣的問題", "又壞了", "怎麼又", "再次失敗"],
      "weak_keywords": ["錯了", "不對", "壞了", "失敗", "沒用", "沒效", "不行", "bug", "broken", "failed", "still broken", "same error", "為什麼還", "怎麼還", "反覆", "踩坑", "又踩", "沒生效", "白做了"],
      "weak_min_match": 3
    }
  },
  "docdrift": {
    "enabled": true,
    "path_mappings": {
      "hooks/wg_*.py": ["Architecture.md"],
      "hooks/workflow-guardian.py": ["Architecture.md"],
      "hooks/extract-worker.py": ["Architecture.md"],
      "hooks/quick-extract.py": ["Architecture.md"],
      "hooks/wisdom_engine.py": ["Architecture.md"],
      "commands/*.md": ["DocIndex-System.md"],
      "rules/*.md": ["DocIndex-System.md"],
      "tools/*.py": ["DocIndex-System.md"]
    },
    "exclude_patterns": [
      "_aidocs/", "memory/", "_staging/", ".git/",
      "node_modules/", "__pycache__/", ".claude/workflow/",
      "backups/", "debug/", "Logs/"
    ],
    "keyword_match_threshold": 2,
    "max_pending_display": 5
  }
}