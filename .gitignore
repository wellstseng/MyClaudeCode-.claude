# ─── Credentials & Auth (NEVER commit) ───────────────────
.credentials.json
mcp-needs-auth-cache.json

# ─── Runtime state (session-specific, auto-generated) ────
backups/
cache/
debug/
downloads/
file-history/
ide/
plans/
plugins/
projects/
session-env/
shell-snapshots/
statsig/
telemetry/
todos/

# ─── Runtime cache files ─────────────────────────────────
stats-cache.json

# ─── Workflow Guardian runtime state ─────────────────────
# config.json IS tracked; state files are not
workflow/state-*.json
workflow/guardian-crash.log

# ─── Memory Vector Service runtime ────────────────────────
memory/_vectordb/*.lance
memory/_vectordb/*.lance/**
memory/_vectordb/service.pid
memory/_vectordb/service.log

# ─── Episodic atoms (TTL 24d, auto-generated) ─────────────
memory/episodic/

# ─── Distant memory archive (expired atoms) ───────────────
memory/_distant/

# ─── User-specific atoms (hardware, local env) ────────────
memory/hardware.md

# ─── Session transcripts (huge, not needed in repo) ───────
projects/*/*.jsonl
projects/*/*/

# ─── Nested .claude (auto-generated by Claude Code) ───────
.claude/

# ─── Node.js runtimes (portable, not tracked) ────────────
tools/node22/

# ─── Python cache ────────────────────────────────────────
__pycache__/
*.pyc

# ─── OS / Editor ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
